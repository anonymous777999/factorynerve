# DPR.ai production example
# Copy to `.env` on the server and replace placeholders.

APP_NAME=DPR.ai
APP_ENV=production
DEBUG=False
LOG_LEVEL=INFO
LOG_FORMAT=json

# Backend bind
FASTAPI_HOST=127.0.0.1
FASTAPI_PORT=8765
ENABLE_AUTH_SECURE_ROUTER=0
AUTH_SECURE_ALLOW_SELF_REGISTER=0

# Frontend -> backend server-side API calls
# Browser requests still use same-origin `/api`.
API_PROXY_ORIGIN=https://factorynerve-api.onrender.com
NEXT_PUBLIC_API_PROXY_ORIGIN=https://factorynerve-api.onrender.com

# Public web URL
WEB_APP_URL=https://app.example.com
EMAIL_VERIFICATION_BASE_URL=https://app.example.com/verify-email?token=
PASSWORD_RESET_BASE_URL=https://app.example.com/reset-password?token=
EMAIL_VERIFICATION_EXPOSE_LINK=false
PASSWORD_RESET_EXPOSE_LINK=false

# Security
JWT_SECRET_KEY=replace_with_32_plus_char_random_secret
AUTH_RESET_SECRET=replace_with_32_plus_char_random_reset_secret
JWT_ACCESS_TOKEN_MINUTES=15
JWT_EXPIRE_HOURS=1
JWT_ISSUER=dpr.ai
JWT_AUDIENCE=dpr-web
REFRESH_TOKEN_DAYS=7
JWT_ACCESS_COOKIE=dpr_access
JWT_REFRESH_COOKIE=dpr_refresh
JWT_CSRF_COOKIE=dpr_csrf
JWT_CSRF_HEADER=X-CSRF-Token
JWT_COOKIE_SAMESITE=Strict
JWT_COOKIE_SECURE=1
JWT_COOKIE_DOMAIN=app.example.com
JWT_COOKIE_PATH=/

# Reverse proxy / HTTPS
CORS_ALLOWED_ORIGINS=https://app.example.com
CORS_ALLOW_CREDENTIALS=true
FORCE_HTTPS=true
TRUST_PROXY=true
HSTS_MAX_AGE=31536000
REDIS_URL=redis://127.0.0.1:6379/0

# PostgreSQL required in production
DATABASE_URL=postgresql+psycopg2://dpr:change_me@127.0.0.1:5432/dpr_ai
DATA_ENCRYPTION_KEY=replace_with_fernet_key
DB_POOL_SIZE=10
DB_POOL_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Rate limiting
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
MAX_REQUEST_BYTES=12000000

# SMTP
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=re_replace_with_resend_api_key
SMTP_FROM=no-reply@example.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_DRY_RUN=false
EMAIL_VERIFICATION_EMAIL_SUBJECT=Verify your DPR.ai email
PASSWORD_RESET_EMAIL_SUBJECT=Reset your DPR.ai password

# Billing (Razorpay)
RAZORPAY_KEY_ID=rzp_live_replace_me
RAZORPAY_KEY_SECRET=replace_with_live_secret
RAZORPAY_WEBHOOK_SECRET=replace_with_webhook_secret

# AI keys
GROQ_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_PROVIDER=groq

# Release / frontend extras
NEXT_PUBLIC_RELEASE_VERSION=
NEXT_PUBLIC_BETA_STAGE=
NEXT_PUBLIC_BETA_BANNER_TEXT=
NEXT_PUBLIC_BETA_FEEDBACK_URL=

# Optional monitoring
SENTRY_DSN=
SENTRY_ENV=production
SENTRY_TRACES_SAMPLE_RATE=0.1
