# =============================================================================
# DPR.ai — PRODUCTION ENVIRONMENT TEMPLATE
# =============================================================================
# Fill in all <REQUIRED> fields before deploying.
# NEVER commit this file with real secrets to version control.
# =============================================================================

# ── App Environment ───────────────────────────────────────────────────────────
APP_NAME=FactoryNerve
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Database (PostgreSQL — SQLite is BLOCKED in production) ──────────────────
DATABASE_URL=<REQUIRED: postgresql+psycopg2://user:pass@host:5432/dpr_ai>
DB_POOL_SIZE=10
DB_POOL_OVERFLOW=10
DB_POOL_TIMEOUT=10
DB_POOL_RECYCLE=1800

# ── Encryption ────────────────────────────────────────────────────────────────
DATA_ENCRYPTION_KEY=<REQUIRED: Fernet key>

# ── JWT / Auth ────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=<REQUIRED: random 64-char hex>
JWT_RSA_PRIVATE_KEY=<OPTIONAL: RSA private key PEM or blank for HS256>
JWT_EXPIRE_HOURS=24
JWT_ACCESS_COOKIE=dpr_access
JWT_REFRESH_COOKIE=dpr_refresh
JWT_CSRF_COOKIE=dpr_csrf
JWT_CSRF_HEADER=X-CSRF-Token
JWT_COOKIE_SAMESITE=Lax
JWT_COOKIE_SECURE=true
JWT_COOKIE_DOMAIN=<REQUIRED: e.g. factorynerve.online>
JWT_COOKIE_PATH=/

# Auth consolidation
AUTH_RESET_SECRET=<REQUIRED: random 64-char hex>
AUTH_SESSION_COOKIE=auth_session
AUTH_CSRF_COOKIE=dpr_csrf
AUTH_CSRF_HEADER=X-CSRF-Token
AUTH_SESSION_SAMESITE=Lax
AUTH_SESSION_SECURE=true
AUTH_SESSION_TTL_MINUTES=1440
SESSION_IDLE_TIMEOUT_MINUTES=30
SESSION_ABSOLUTE_TIMEOUT_HOURS=24
AUTH_LOCKOUT_THRESHOLD=5
AUTH_LOCKOUT_DURATION_MINUTES=15
AUTH_PERSISTENT_LOCKOUT_ATTEMPTS=20
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_PASSWORD_RESET_TTL_MINUTES=30
PASSWORD_EXPIRY_DAYS=90
EMAIL_VERIFICATION_EXPOSE_LINK=0
PASSWORD_RESET_EXPOSE_LINK=0
EMAIL_VERIFICATION_BASE_URL=<REQUIRED>
PASSWORD_RESET_BASE_URL=<REQUIRED>
FRONTEND_URL=<REQUIRED>
FRONTEND_OAUTH_REDIRECT=<REQUIRED>

# ── AI Providers ──────────────────────────────────────────────────────────────
AI_PROVIDER=groq
GROQ_API_KEY=<REQUIRED>
ANTHROPIC_API_KEY=<REQUIRED>
GEMINI_API_KEY=<OPTIONAL>
OPENAI_API_KEY=<OPTIONAL>
AI_PROVIDER_TIMEOUT_SECONDS=25
AI_PROVIDER_RETRY_ATTEMPTS=2

# ── OCR ───────────────────────────────────────────────────────────────────────
OCR_NEW_CONFIDENCE_ENABLED=true
OCR_HANDWRITING_DETECTION_ENABLED=true
OCR_CROSS_VALIDATION_ENFORCED=true
OCR_PROVIDER_TIMEOUT_SECONDS=30

# ── Email (real SMTP) ─────────────────────────────────────────────────────────
SMTP_DRY_RUN=0
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=<REQUIRED>
SMTP_FROM=noreply@<REQUIRED>
SMTP_USE_TLS=true
SMTP_USE_SSL=false
RESEND_API_KEY=<REQUIRED or empty if using SMTP>
EMAIL_MAX_RETRIES=5
EMAIL_BATCH_SIZE=10

# ── SMS / WhatsApp ────────────────────────────────────────────────────────────
SMS_PROVIDER=whatsapp
WHATSAPP_PROVIDER_MODE=meta
META_WA_PHONE_NUMBER_ID=<REQUIRED>
META_WA_ACCESS_TOKEN=<REQUIRED>
META_WA_WEBHOOK_VERIFY_TOKEN=<REQUIRED>
META_WA_APP_SECRET=<REQUIRED>

# ── Billing (Razorpay Live) ──────────────────────────────────────────────────
RAZORPAY_KEY_ID=<REQUIRED: live key_id>
RAZORPAY_KEY_SECRET=<REQUIRED: live key_secret>
RAZORPAY_WEBHOOK_SECRET=<REQUIRED>
ENABLE_BILLING_PLAN_OVERRIDE=0
TRIAL_DAYS=7
BILLING_GRACE_DAYS=3

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
LOGIN_RATE_LIMIT_MAX_REQUESTS=5

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=<REQUIRED>

# ── Monitoring ────────────────────────────────────────────────────────────────
METRICS_TOKEN=<REQUIRED>
SENTRY_DSN=<OPTIONAL>
SENTRY_ENV=production
SENTRY_TRACES_SAMPLE_RATE=0.1
ALERTS_ENABLED=true

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_BILLING_PLAN_OVERRIDE=0
OCR_DEFAULT_PLAN=pilot
