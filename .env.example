GROQ_API_KEY=your_groq_key_here
ANTHROPIC_API_KEY=your_claude_key_here
GEMINI_API_KEY=your_gemini_key_here
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini
AI_PROVIDER=groq
AI_THREAD_WORKERS=4
AI_PROVIDER_TIMEOUT_SECONDS=20
AI_PROVIDER_RETRY_ATTEMPTS=3
AI_PROVIDER_RETRY_BACKOFF_SECONDS=1.5
AI_CIRCUIT_BREAKER_THRESHOLD=3
AI_CIRCUIT_BREAKER_COOLDOWN_SECONDS=180

# Auth secure (cookie sessions + MFA)
AUTH_SESSION_COOKIE=auth_session
AUTH_CSRF_COOKIE=auth_csrf
AUTH_CSRF_HEADER=X-CSRF-Token
AUTH_SESSION_TTL_MINUTES=1440
AUTH_SESSION_SAMESITE=Lax
AUTH_SESSION_SECURE=1
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_PASSWORD_RESET_TTL_MINUTES=30
AUTH_RESET_BASE_URL=http://127.0.0.1:8765/auth-secure/password/reset
AUTH_RESET_SECRET=change_this_reset_secret
AUTH_MFA_ISSUER=DPR.ai
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8765/auth/google/callback
FRONTEND_OAUTH_REDIRECT=http://127.0.0.1:3000
LEDGER_SCAN_MOCK=0
TABLE_SCAN_PROVIDER=tesseract
TABLE_SCAN_PROVIDER_CHAIN=anthropic,tesseract
LEDGER_SCAN_PROVIDER=anthropic
LEDGER_SCAN_PROVIDER_CHAIN=anthropic,tesseract
OCR_ANTHROPIC_MODEL=claude-3-5-haiku-20241022
BYTEZ_API_KEY=your_bytez_key_here
BYTEZ_MODEL_ID=google/gemma-3-4b-it
BYTEZ_PROVIDER_KEY=optional_closed_source_provider_key
BYTEZ_IMAGE_URL=https://your-public-image-url.jpg

APP_NAME=DPR.ai
APP_ENV=development
DEBUG=False
LOG_LEVEL=INFO
LOG_FORMAT=text
SENTRY_DSN=
SENTRY_ENV=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# WhatsApp (Twilio)
WHATSAPP_ALERTS_ENABLED=false
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO_DEFAULT=

# Generic WhatsApp alert backend
WHATSAPP_PROVIDER=meta
WHATSAPP_API_KEY=your_provider_api_key
WHATSAPP_API_URL=
WHATSAPP_SENDER_ID=your_sender_phone_or_provider_id
WHATSAPP_TIMEOUT_SECONDS=10
WHATSAPP_RETRY_ATTEMPTS=3
WHATSAPP_RETRY_BACKOFF_SECONDS=1.5

# Feedback translation
FEEDBACK_TRANSLATION_PROVIDER=
FEEDBACK_TRANSLATION_API_URL=
FEEDBACK_TRANSLATION_API_KEY=
FEEDBACK_TRANSLATION_TIMEOUT_SECONDS=4

# Ops alerting
ALERTS_ENABLED=false
ALERTS_PROVIDER=twilio
ALERT_APP_NAME=DPR.ai
ALERT_TIMEZONE=Asia/Kolkata
DEPLOYMENT_ENV=development
ALERT_ALLOWED_ENVS=production
ALERT_DISPATCH_WORKERS=2
ALERT_RETRY_ATTEMPTS=3
ALERT_RETRY_BACKOFF_SECONDS=1.5
ALERT_DEFAULT_COOLDOWN_SECONDS=600
ALERT_T1_5XX_WINDOW_SECONDS=300
ALERT_T1_5XX_MIN_COUNT=10
ALERT_T1_5XX_MIN_PERCENT=5
ALERT_T2_OCR_WINDOW_SECONDS=300
ALERT_T2_OCR_MIN_FAILURES=10
ALERT_T4_AUTH_WINDOW_SECONDS=600
ALERT_T4_AUTH_MIN_ATTEMPTS=8
ALERT_T5_ERROR_WINDOW_SECONDS=300
ALERT_T5_MIN_REQUESTS=100
ALERT_T5_WARN_PERCENT=5
ALERT_T5_CRITICAL_PERCENT=15
ALERT_ORG_RATE_LIMIT_WINDOW_SECONDS=600
ALERT_ORG_RATE_LIMIT_NORMAL_MAX=20
ALERT_ORG_RATE_LIMIT_CRITICAL_MAX=50
ALERT_ESCALATION_WINDOW_SECONDS=1800
ALERT_ESCALATION_HIGH_REPEAT_COUNT=3
ALERT_ESCALATION_CRITICAL_REPEAT_COUNT=5
ALERT_DAILY_SUMMARY_HOUR_UTC=18
ALERT_DAILY_SUMMARY_MINUTE_UTC=0
REDIS_URL=

DATABASE_URL=sqlite:///dpr_ai.db
# DATABASE_URL=postgresql+psycopg2://dpr:dpr@localhost:5432/dpr_ai
SQLITE_SOURCE_URL=sqlite:///dpr_ai.db
DATA_ENCRYPTION_KEY=replace_with_fernet_key

# Database pool (PostgreSQL only)
DB_POOL_SIZE=10
DB_POOL_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

JWT_SECRET_KEY=change_this_secret
JWT_EXPIRE_HOURS=24

# JWT cookie auth (web frontend)
JWT_ACCESS_COOKIE=dpr_access
JWT_REFRESH_COOKIE=dpr_refresh
JWT_CSRF_COOKIE=dpr_csrf
JWT_CSRF_HEADER=X-CSRF-Token
JWT_COOKIE_SAMESITE=Lax
JWT_COOKIE_SECURE=1
JWT_COOKIE_DOMAIN=
JWT_COOKIE_PATH=/

FASTAPI_PORT=8765

# CORS and HTTPS hardening
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
FORCE_HTTPS=false
TRUST_PROXY=false
HSTS_MAX_AGE=31536000
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
MAX_REQUEST_BYTES=12000000

DPR_API_BASE_URL=http://127.0.0.1:8765
DPR_DISABLE_AI_SUMMARY=0
BACKUP_DIR=./backups
SHIFT_MISSED_ALERT_HOUR=18
METRICS_TOKEN=
BILLING_GRACE_DAYS=3
WEB_APP_URL=http://127.0.0.1:3000

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_DRY_RUN=false
EMAIL_VERIFICATION_BASE_URL=http://127.0.0.1:3000/verify-email?token=
EMAIL_VERIFICATION_EXPOSE_LINK=true
EMAIL_VERIFICATION_EMAIL_SUBJECT=Verify your DPR.ai email
PASSWORD_RESET_EXPOSE_LINK=true

# Analytics gating
ANALYTICS_BASIC_MIN_PLAN=growth
ANALYTICS_FULL_MIN_PLAN=factory

# Remember-me storage (unsafe on shared devices)
REMEMBER_ME_UNSAFE=0

# Password reset (legacy JWT auth)
PASSWORD_RESET_TTL_MINUTES=30
PASSWORD_RESET_BASE_URL=http://127.0.0.1:3000/reset-password?token=
PASSWORD_RESET_EMAIL_SUBJECT=Reset your DPR.ai password
PASSWORD_RESET_PEPPER=change_this_pepper

# Beta rollout and release banner (Next.js)
NEXT_PUBLIC_BETA_STAGE=
NEXT_PUBLIC_BETA_BANNER_TEXT=
NEXT_PUBLIC_BETA_FEEDBACK_URL=
NEXT_PUBLIC_RELEASE_VERSION=
