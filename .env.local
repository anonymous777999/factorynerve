# =============================================================================
# DPR.ai — LOCAL DEVELOPMENT ENVIRONMENT
# =============================================================================
# Loaded when APP_ENV=development (default).
# Copy this file as a starting point: cp .env.local .env
# =============================================================================

# ── App Environment ───────────────────────────────────────────────────────────
APP_NAME=DPR.ai
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG
LOG_FORMAT=text
FASTAPI_PORT=8765

# ── Database (SQLite — mimics PostgreSQL via PRAGMAs) ─────────────────────────
# On SQLite, foreign_keys, WAL mode, and busy_timeout are set in database.py.
# To switch to PostgreSQL later, just change DATABASE_URL:
#   DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/dpr_ai
DATABASE_URL=sqlite:///dpr_ai.db
DB_POOL_SIZE=5
DB_POOL_OVERFLOW=5
DB_POOL_TIMEOUT=10
DB_POOL_RECYCLE=1800

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATA_ENCRYPTION_KEY=dGVzdC1lbmNyeXB0aW9uLWtleS0zMi1ieXRlcy0hIQ==

# ── JWT / Auth ────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=dev-secret-key-do-not-use-in-prod-abc123
JWT_RSA_PRIVATE_KEY=
JWT_EXPIRE_HOURS=24
JWT_ACCESS_COOKIE=dpr_access
JWT_REFRESH_COOKIE=dpr_refresh
JWT_CSRF_COOKIE=dpr_csrf
JWT_CSRF_HEADER=X-CSRF-Token
JWT_COOKIE_SAMESITE=Lax
JWT_COOKIE_SECURE=false
JWT_COOKIE_DOMAIN=

# Auth consolidation (cookie-based sessions)
AUTH_RESET_SECRET=dev-auth-reset-secret-do-not-use-in-prod
AUTH_SESSION_COOKIE=auth_session
AUTH_CSRF_COOKIE=dpr_csrf
AUTH_CSRF_HEADER=X-CSRF-Token
AUTH_SESSION_SAMESITE=Lax
AUTH_SESSION_SECURE=false
AUTH_SESSION_TTL_MINUTES=1440
SESSION_IDLE_TIMEOUT_MINUTES=30
SESSION_ABSOLUTE_TIMEOUT_HOURS=24
AUTH_LOCKOUT_THRESHOLD=5
AUTH_LOCKOUT_DURATION_MINUTES=15
AUTH_PERSISTENT_LOCKOUT_ATTEMPTS=20
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX_ATTEMPTS=100000
AUTH_PASSWORD_RESET_TTL_MINUTES=30

# Expose verification/reset links in dev (clickable in console)
EMAIL_VERIFICATION_EXPOSE_LINK=1
PASSWORD_RESET_EXPOSE_LINK=1
EMAIL_VERIFICATION_BASE_URL=http://127.0.0.1:3000/verify-email?token=
PASSWORD_RESET_BASE_URL=http://127.0.0.1:3000/reset-password?token=
FRONTEND_URL=http://127.0.0.1:3000
FRONTEND_OAUTH_REDIRECT=http://127.0.0.1:3000

# ── AI Providers (mock/real) ──────────────────────────────────────────────────
# Set at least one real key to test AI features.
# For pure mock mode, leave as "test" — the app will use fallback paths.
AI_PROVIDER=groq
GROQ_API_KEY=test
ANTHROPIC_API_KEY=test
GEMINI_API_KEY=test
OPENAI_API_KEY=test

# AI timeouts and retries
AI_PROVIDER_TIMEOUT_SECONDS=2
AI_PROVIDER_RETRY_ATTEMPTS=1
AI_PROVIDER_RETRY_BACKOFF_SECONDS=0

# Intelligence engine
INTELLIGENCE_PROVIDER_CHAIN=anthropic,groq,openai
INTELLIGENCE_RETRY_ATTEMPTS=1
INTELLIGENCE_RETRY_BACKOFF_SECONDS=0.5
INTELLIGENCE_PROVIDER_TIMEOUT_SECONDS=3
INTELLIGENCE_MAX_OUTPUT_TOKENS=700
INTELLIGENCE_REQUESTS_PER_MINUTE=100
INTELLIGENCE_CACHE_TTL_SECONDS=43200

# ── OCR ───────────────────────────────────────────────────────────────────────
OCR_NEW_CONFIDENCE_ENABLED=true
OCR_HANDWRITING_DETECTION_ENABLED=false
OCR_CROSS_VALIDATION_ENFORCED=true
OCR_SERVER_SIDE_CACHE_HASH=true
OCR_PROVIDER_TIMEOUT_SECONDS=15
CELL_FORMAT_V2=false

# Tesseract OCR path (Windows default, adjust if needed)
# TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# ── Email (Dry Run — logs to console, never sends) ────────────────────────────
SMTP_DRY_RUN=1
SMTP_HOST=127.0.0.1
SMTP_PORT=1025         # Mailpit / MailHog default port
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=dev@example.com
SMTP_USE_TLS=false
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=5
RESEND_API_KEY=
RESEND_API_TIMEOUT_SECONDS=5
EMAIL_MAX_RETRIES=1
EMAIL_BATCH_SIZE=10
EMAIL_POLL_INTERVAL_SECONDS=60
EMAIL_QUEUE_POLL_INTERVAL_SECONDS=60

# ── SMS / WhatsApp (Mock mode) ────────────────────────────────────────────────
SMS_PROVIDER=mock
WHATSAPP_PROVIDER_MODE=mock
META_WA_PHONE_NUMBER_ID=
META_WA_ACCESS_TOKEN=
META_WA_API_VERSION=v19.0
META_WA_WEBHOOK_VERIFY_TOKEN=dev-verify-token
META_WA_APP_SECRET=
WA_DAILY_SEND_CAP=500
WA_DEDUP_WINDOW_SECONDS=5

# ── Billing (Razorpay Test Mode) ──────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_key
RAZORPAY_KEY_SECRET=rzp_test_secret
RAZORPAY_WEBHOOK_SECRET=whsec_test_secret
ENABLE_BILLING_PLAN_OVERRIDE=1
TRIAL_DAYS=30
BILLING_GRACE_DAYS=7

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8765/auth/google/callback

# ── Rate Limiting (very high in dev) ──────────────────────────────────────────
RATE_LIMIT_WINDOW_SECONDS=1
RATE_LIMIT_MAX_REQUESTS=100000
LOGIN_RATE_LIMIT_MAX_REQUESTS=100000
REGISTER_RATE_LIMIT_MAX_REQUESTS=100000
OCR_RATE_LIMIT_MAX_REQUESTS=100000
INVITE_RATE_LIMIT_MAX_REQUESTS=100000

# ── CORS / Security ───────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8502,http://127.0.0.1:8502
CORS_ALLOW_CREDENTIALS=true
FORCE_HTTPS=false
TRUST_PROXY=false
HSTS_MAX_AGE=0
CONTENT_SECURITY_POLICY=
MAX_REQUEST_BYTES=12000000

# ── Cache ─────────────────────────────────────────────────────────────────────
# Redis URL — leave empty to use in-memory cache fallback
REDIS_URL=
CACHE_MEMORY_MAX_ITEMS=512

# ── Background Jobs ───────────────────────────────────────────────────────────
BACKGROUND_JOB_WORKERS=4
BACKGROUND_JOB_TTL_SECONDS=86400
BACKGROUND_JOB_HISTORY_LIMIT=25

# ── Monitoring / Observability ────────────────────────────────────────────────
METRICS_TOKEN=dev-metrics-token
SENTRY_DSN=
SENTRY_ENV=development
SENTRY_TRACES_SAMPLE_RATE=0.0
ALERTS_ENABLED=false
ALERT_APP_NAME=DPR.ai-local

# ── Ops Alerts (disabled in dev) ──────────────────────────────────────────────
ALERT_TIMEZONE=Asia/Kolkata
ALERT_ALLOWED_ENVS=production
ALERT_DISPATCH_WORKERS=1
ALERT_DEFAULT_COOLDOWN_SECONDS=600

# ── Audit Archival (no-op on SQLite) ─────────────────────────────────────────
AUDIT_ARCHIVAL_ENABLED=false

# ── Feature Flags ─────────────────────────────────────────────────────────────
DPR_DISABLE_AI_SUMMARY=0
SMART_INPUT_AI_FALLBACK=1
ENABLE_BILLING_PLAN_OVERRIDE=1
OCR_DEFAULT_PLAN=pilot

# ── Invoice Config ────────────────────────────────────────────────────────────
INVOICE_SELLER_NAME=DPR.ai Local Dev
INVOICE_SELLER_GSTIN=29ABCDE1234F1Z5
INVOICE_SELLER_ADDRESS=123 Dev Street, Bangalore
INVOICE_SELLER_STATE=Karnataka
INVOICE_SELLER_STATE_CODE=29
INVOICE_SELLER_PAN=ABCDE1234F
INVOICE_SELLER_EMAIL=billing@dev.local
INVOICE_SAC_CODE=998314
INVOICE_GST_RATE=18.0

# ── Seeds ─────────────────────────────────────────────────────────────────────
# Uncomment to automatically seed on startup:
# AUTO_SEED_ON_STARTUP=1
