# =============================================================================
# DPR.ai — TEST ENVIRONMENT (for pytest)
# =============================================================================
# These values are set automatically by tests/conftest.py.
# This file exists as documentation/reference for what the test env expects.
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=DPR.ai Test
APP_ENV=testing
DEBUG=true
LOG_LEVEL=WARNING
LOG_FORMAT=json

# ── Database ──────────────────────────────────────────────────────────────────
# Tests create their own temporary SQLite database automatically.
# Override with DPR_TEST_DATABASE_URL env var if needed.
# DATABASE_URL=sqlite:///test_runtime.db

# ── AI (mock keys, fast timeouts) ─────────────────────────────────────────────
AI_PROVIDER=groq
GROQ_API_KEY=test
ANTHROPIC_API_KEY=test
GEMINI_API_KEY=test
OPENAI_API_KEY=test
AI_PROVIDER_TIMEOUT_SECONDS=1
AI_PROVIDER_RETRY_ATTEMPTS=1
AI_PROVIDER_RETRY_BACKOFF_SECONDS=0

# ── Rate Limits (very high — tests must not be throttled) ─────────────────────
RATE_LIMIT_MAX_REQUESTS=100000
RATE_LIMIT_WINDOW_SECONDS=1
AUTH_RATE_LIMIT_MAX_ATTEMPTS=100000
REGISTER_RATE_LIMIT_MAX_REQUESTS=100000
LOGIN_RATE_LIMIT_MAX_REQUESTS=100000
OCR_RATE_LIMIT_MAX_REQUESTS=100000
INVITE_RATE_LIMIT_MAX_REQUESTS=100000

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=test-secret
AUTH_SESSION_SECURE=false
JWT_COOKIE_SECURE=false
EMAIL_VERIFICATION_EXPOSE_LINK=1
PASSWORD_RESET_EXPOSE_LINK=1

# ── Encryption ────────────────────────────────────────────────────────────────
# DATA_ENCRYPTION_KEY is auto-generated by conftest.py

# ── Email (dry run only) ──────────────────────────────────────────────────────
SMTP_DRY_RUN=1

# ── Billing (test keys) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_key
RAZORPAY_KEY_SECRET=rzp_test_secret
RAZORPAY_WEBHOOK_SECRET=whsec_test

# ── Background Jobs (synchronous in tests) ────────────────────────────────────
BACKGROUND_JOB_WORKERS=1

# ── Cache (no Redis needed) ───────────────────────────────────────────────────
REDIS_URL=
