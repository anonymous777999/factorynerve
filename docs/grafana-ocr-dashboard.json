{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source for DPR.ai metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "5.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "title": "DPR.ai OCR Observability",
  "uid": "dpr-ocr-observability",
  "tags": ["dpr", "ocr", "observability"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Throughput (docs/min)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(dpr_ocr_jobs_total[1m])",
          "legendFormat": "Docs/min",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cpm",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 20 }
          ]}
        }
      }
    },
    {
      "id": 2,
      "title": "Average Cost / Document",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 0 },
      "targets": [
        {
          "expr": "rate(dpr_ocr_tier_cost_usd_total[5m]) / rate(dpr_ocr_jobs_total[5m])",
          "legendFormat": "$/doc",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.005 },
            { "color": "red", "value": 0.01 }
          ]}
        }
      }
    },
    {
      "id": 3,
      "title": "Success Rate",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "dpr_ocr_extraction_success_rate",
          "legendFormat": "Success Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.8 },
            { "color": "green", "value": 0.9 }
          ]}
        }
      }
    },
    {
      "id": 4,
      "title": "Cache Hit Ratio",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "dpr_ocr_cache_hit_ratio",
          "legendFormat": "Cache Hit",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.1 },
            { "color": "green", "value": 0.5 }
          ]}
        }
      }
    },
    {
      "id": 5,
      "title": "User Correction Rate",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "dpr_ocr_user_correction_rate",
          "legendFormat": "Correction Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.10 },
            { "color": "red", "value": 0.15 }
          ]}
        }
      }
    },
    {
      "id": 6,
      "title": "Classification Accuracy",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 20, "y": 0 },
      "targets": [
        {
          "expr": "dpr_ocr_classification_accuracy",
          "legendFormat": "Accuracy",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.8 },
            { "color": "green", "value": 0.9 }
          ]}
        }
      }
    },
    {
      "id": 7,
      "title": "Processing Time (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(dpr_ocr_job_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(dpr_ocr_job_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(dpr_ocr_job_duration_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 8,
      "title": "Cost Trend (Daily)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "rate(dpr_ocr_tier_cost_usd_total[1d])",
          "legendFormat": "Daily",
          "refId": "A"
        },
        {
          "expr": "rate(dpr_ocr_cost_saved_usd_total[1d])",
          "legendFormat": "Saved vs Opus",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 9,
      "title": "Model Tier Distribution",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "rate(dpr_ocr_model_tier_requests_total[5m])",
          "legendFormat": "{{tier}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }
          ]}
        }
      }
    },
    {
      "id": 10,
      "title": "Error Rate by Document Type",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 14 },
      "targets": [
        {
          "expr": "rate(dpr_ocr_jobs_total{status=\"failure\"}[5m])",
          "legendFormat": "Errors",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cpm",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        }
      }
    },
    {
      "id": 11,
      "title": "Correction Pass Rate",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 14 },
      "targets": [
        {
          "expr": "rate(dpr_ocr_correction_passes_total{status=\"success\"}[1h]) / rate(dpr_ocr_correction_passes_total[1h])",
          "legendFormat": "Correction Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.15 },
            { "color": "red", "value": 0.20 }
          ]}
        }
      }
    },
    {
      "id": 12,
      "title": "Recent Processing Logs",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "sort_desc(dpr_ocr_jobs_total[1h])",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "displayMode": "table",
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 13,
      "title": "Total Exports (Counter)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 30 },
      "targets": [
        {
          "expr": "dpr_ocr_exports_total",
          "legendFormat": "Exports",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }
          ]}
        }
      }
    },
    {
      "id": 14,
      "title": "Total Cost Saved vs Opus Baseline",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 30 },
      "targets": [
        {
          "expr": "dpr_ocr_cost_saved_usd_total",
          "legendFormat": "Saved",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 15,
      "title": "Active Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 30 },
      "targets": [
        {
          "expr": "dpr_http_active_requests",
          "legendFormat": "Active",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 10 },
            { "color": "red", "value": 50 }
          ]}
        }
      }
    }
  ],
  "rows": [],
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "hide": 0
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "name": "Errors",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "enable": true,
        "expr": "dpr_exceptions_total > 0",
        "iconColor": "red",
        "showIn": 0
      }
    ]
  }
}
